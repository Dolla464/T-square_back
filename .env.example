###########################################################
# Application
###########################################################
APP_NAME="T-Square LMS"
# Use "production" on live servers, "local" for development.
APP_ENV=production
# Generate with: php artisan key:generate
APP_KEY=
# Never enable debug in production (leaks stack traces & secrets).
APP_DEBUG=false
# Public URL of the backend (no trailing slash).
APP_URL=https://example.com
# Public URL of the frontend SPA. Used by CORS & Sanctum.
FRONTEND_URL=https://app.example.com
# Secondary / production CDN URL for the frontend (e.g. Vercel, Netlify, custom domain).
# Both FRONTEND_URL and FRONTEND_URL_PROD are added to CORS allowed_origins.
FRONTEND_URL_PROD=https://your-frontend-production-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

# Password hashing cost factor (higher = slower & more secure).
BCRYPT_ROUNDS=12

###########################################################
# Logging
###########################################################
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Use "debug" locally, "error" or "warning" in production.
LOG_LEVEL=error

###########################################################
# Database
###########################################################
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

###########################################################
# Session & Authentication (Sanctum SPA)
###########################################################
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Set to the root domain serving the cookie (e.g. .example.com).
SESSION_DOMAIN=null
# Domains allowed to make stateful (cookie) Sanctum requests.
SANCTUM_STATEFUL_DOMAINS=app.example.com
# Optional token prefix to help secret scanners detect leaked tokens.
# SANCTUM_TOKEN_PREFIX=

###########################################################
# Queue, Cache & Broadcasting
###########################################################
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

###########################################################
# Mail
###########################################################
# Drivers: smtp, sendmail, mailgun, ses, postmark, log, array
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Mailtrap sandbox (uncomment & switch MAIL_MAILER=smtp to use):
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=587
# MAIL_USERNAME=your_mailtrap_username
# MAIL_PASSWORD=your_mailtrap_password

###########################################################
# Third-Party Services / AWS S3
###########################################################
# AWS / S3 credentials. Create an IAM user with S3 access and
# paste its access key & secret here. Leave blank if unused.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

###########################################################
# API Documentation (Scramble)
###########################################################
# Version string shown in the generated OpenAPI docs.
# API_VERSION=0.0.1

###########################################################
# Frontend (Vite)
###########################################################
VITE_APP_NAME="${APP_NAME}"